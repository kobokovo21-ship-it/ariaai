{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "BLOB_READ_WRITE_TOKEN",
    "BLOB_STORE_ID",
    "BLOB_WEBHOOK_PUBLIC_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "create-snapshot": {
      "cache": false,
      "dependsOn": ["build"]
    }
  }
}
