{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/makler/:slug", "destination": "/makler/index.html" },
    { "source": "/makler/:slug/", "destination": "/makler/index.html" }
  ]
}
